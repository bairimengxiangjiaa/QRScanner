<?xml version="1.0" encoding="utf-8"?>
<!--
    网络安全配置

    设计目的：
        显式声明应用的网络安全策略，而非依赖系统默认值。
        明确禁止明文 HTTP 流量，强制所有网络连接使用 HTTPS 加密。

    能做到：
        - 禁止 cleartext（HTTP）流量，防止 MITM 中间人攻击
        - 防止未来开发中意外使用 HTTP 接口

    做不到：
        - 不校验 TLS 证书链（使用系统默认信任锚点）
        - 不做证书固定（pinning），如需更高安全性可后续添加
-->
<network-security-config>
    <!-- 禁止明文 HTTP 流量 -->
    <base-config cleartextTrafficPermitted="false">
        <!-- 使用系统默认信任锚点验证 TLS 证书 -->
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
