# Release 签名配置模板
# 复制此文件为 keystore.properties 并填入真实值
# ⚠️ keystore.properties 不应提交到版本控制（已在 .gitignore 中排除）
#
# 生成 keystore 命令：
#   keytool -genkeypair -v -keystore release.keystore -alias qrscanner -keyalg RSA -keysize 2048 -validity 10000

storeFile=release.keystore
storePassword=your_store_password
keyAlias=qrscanner
keyPassword=your_key_password
